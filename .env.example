# OpenAI — get a key at https://platform.openai.com/api-keys
# IMPORTANT: Never commit real keys. Rotate any key that was shared in chat or email.
OPENAI_API_KEY=sk-your-openai-key-here

# Lakera Guard — get a key at https://platform.lakera.ai/
LAKERA_API_KEY=your-lakera-api-key-here

# Optional: Lakera project ID for a custom policy (uses default policy if omitted)
LAKERA_PROJECT_ID=your-lakera-project-id

# Optional: OpenAI model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
